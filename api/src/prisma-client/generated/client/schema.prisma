generator client {
  provider = "prisma-client-js"
  output   = "../src/prisma-client/generated/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model init {
  id    Int    @id @default(autoincrement())
  ok    String @db.VarChar(255)
  fw    String @db.VarChar(255)
  awdwa String @db.VarChar(255)
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
}
